# MCP Server Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ── Server Settings ──────────────────────────────────────
HOST=0.0.0.0
REST_PORT=8001
MCP_SSE_PORT=8002
LOG_LEVEL=INFO

# ── Cookidoo Credentials ─────────────────────────────────
# Required for authenticating with the Cookidoo platform.
# In production, use Azure Key Vault instead of env vars.
COOKIDOO_EMAIL=your-email@example.com
COOKIDOO_PASSWORD=your-password

# ── Databricks Connection (optional) ─────────────────────
# Only needed if the MCP server pushes data directly to Databricks.
# Typically, Databricks pulls from the MCP server instead.
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=your-token
