# Cookidoo Agent Assistant - Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Application Settings ─────────────────────────────────
ENV=development
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ── CORS Settings ────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Azure Key Vault ──────────────────────────────────────
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Databricks Settings ──────────────────────────────────
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-token
DATABRICKS_CATALOG=cookidoo_agent
DATABRICKS_SCHEMA=main

# ── LLM Model Settings ───────────────────────────────────
LLM_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_ENDPOINT_NAME=cookidoo-agent-primary

# ── AgentBricks Settings ─────────────────────────────────
AGENTBRICKS_ENABLED=true
AGENTBRICKS_MAX_ITERATIONS=5

# ── MCP Server Settings ──────────────────────────────────
MCP_SERVER_URL=http://localhost:8001
MCP_SSE_URL=http://localhost:8002
MCP_TIMEOUT=30
MCP_LOG_LEVEL=INFO

# ── Cookidoo Credentials ─────────────────────────────────
# In production these are fetched from Azure Key Vault.
# For local development, set them here.
COOKIDOO_EMAIL=your-email@example.com
COOKIDOO_PASSWORD=your-password
COOKIDOO_COUNTRY_CODE=us
COOKIDOO_LANGUAGE=en-US
COOKIDOO_URL=https://cookidoo.thermomix.com/foundation/en-US

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── Cache Settings ────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL=3600

# ── Sentry (Error Tracking) - Optional ───────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
